@startuml Architecture

skinparam packageStyle rectangle

package "Proto Definitions (proto/)" as P {
}

package "gRPC Services (grpc/)" as S {
    class LidarServiceImpl {
        -lidar : ILidar
    }
    class ImuServiceImpl {
        -imu : IImu
    }
    class CameraServiceImpl {
        -camera : ICamera
    }
    class AdcServiceImpl {
        -adc : IAdc
    }
}

package "Sensor Interfaces (include/interface/)" as I {
    interface ILidar
    interface IImu
    interface ICamera
    interface IAdc
}

package "Sensor Drivers (src/)" as D {
    class RPLidar
    class Mid360
    class ICM20948
    class OpenCvCamera
    class ADS1115
}

' Proto generates services
P ..> S : generates

' Services depend on Interfaces (dependency injection)
LidarServiceImpl o-- ILidar
ImuServiceImpl o-- IImu
CameraServiceImpl o-- ICamera
AdcServiceImpl o-- IAdc

' Force Drivers below Interfaces
I -down[hidden]- D

' Drivers implement Interfaces
RPLidar .up.|> ILidar
Mid360 .up.|> ILidar
ICM20948 .up.|> IImu
OpenCvCamera .up.|> ICamera
ADS1115 .up.|> IAdc
@enduml