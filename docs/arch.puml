@startuml Architecture

skinparam packageStyle rectangle

package "Proto Definitions (proto/)" as P {
}

package "gRPC Services (grpc/)" as S {
    class LidarServiceImpl {
        -lidar : ILidar
    }
    class ImuServiceImpl {
        -imu : IImu
    }
    class CameraServiceImpl {
        -camera : ICamera
    }
    class AdcServiceImpl {
        -adc : IAdc
    }
}

package "Python Client (client/)" as C {
    class SensorClient {
        -channel : grpc.Channel
        +stream_lidar() : Iterator[PointCloud3]
        +stream_imu() : Iterator[IMUData]
        +stream_camera() : Iterator[CameraStreamReply]
        +get_adc(channel) : AdcData
    }
}

' Keep client beside services
S -right[hidden]- C

package "Sensor Interfaces (include/interface/)" as I {
    interface ILidar
    interface IImu
    interface ICamera
    interface IAdc
}

package "Sensor Drivers (src/)" as D {
    class RPLidar
    class Mid360
    class ICM20948
    class OpenCvCamera
    class ADS1115
}

' Proto generates services
P ..> S : generates

' Services depend on Interfaces (dependency injection)
LidarServiceImpl o-- ILidar
ImuServiceImpl o-- IImu
CameraServiceImpl o-- ICamera
AdcServiceImpl o-- IAdc

' Force Drivers below Interfaces
I -down[hidden]- D

' Drivers implement Interfaces
RPLidar .up.|> ILidar
Mid360 .up.|> ILidar
ICM20948 .up.|> IImu
OpenCvCamera .up.|> ICamera
ADS1115 .up.|> IAdc

' Proto generates client stubs used by the Python client
P ..> C : generates stubs

' Client calls gRPC services
SensorClient --> LidarServiceImpl : getLidarScan
SensorClient --> ImuServiceImpl : getImuData
SensorClient --> CameraServiceImpl : getCameraFrame
SensorClient --> AdcServiceImpl : getAdcData
@enduml